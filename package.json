{
  "name": "bygoetz",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 111",
    "safari >= 15",
    "ios_saf >= 15"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:meta": "node --experimental-strip-types tests/basil-meta.test.ts",
    "test:phase4": "node --experimental-strip-types tests/basil-urls.test.ts",
    "test:commons": "node --experimental-strip-types tests/basil-commons.test.ts",
    "test:watering": "node --experimental-strip-types tests/basil-watering-selection.test.ts",
    "test:phase5": "node --experimental-strip-types tests/basil-phase5-reliability.test.ts",
    "test:load:mock": "node scripts/basil-load-test.mjs --mock --users 5 --seconds 3",
    "test:browser:phase5": "node scripts/basil-browser-check.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "resend": "latest",
    "stripe": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.10",
    "typescript": "6.0.3"
  }
}

